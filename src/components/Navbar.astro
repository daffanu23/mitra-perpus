---
// src/components/Navbar.astro
import ThemeToggle from './ThemeToggle.jsx';

const isLoggedIn = Astro.cookies.has('session');
const userRole = Astro.cookies.get('role')?.value || 'user';
const userName = "Rifki"; 
---

<nav class="navbar">
  <div class="nav-brand">
    <a href="/" class="logo">Mita.</a>
  </div>
  
  <button class="hamburger" id="hamburger-btn" aria-label="Menu">
    <svg viewBox="0 0 24 24" width="28" height="28" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>

  <div class="nav-menu" id="nav-menu">
    <ul class="nav-links">
      <li><a href="/">Beranda</a></li>
      <li><a href="/search">Buku</a></li>
      <li><a href="/pustakaku">Pustakaku</a></li>
      {userRole === 'admin' && (
        <li><a href="/admin" class="admin-link">Panel admin</a></li>
      )}
    </ul>

    <div class="user-profile">
      <ThemeToggle client:load />

      {isLoggedIn ? (
        <a href="/profile" class="profile-info">
          <span>Hai {userName}</span>
          <div class="avatar"><img src="https://api.dicebear.com/7.x/avataaars/svg?seed=Rifki" alt="Avatar" /></div>
        </a>
      ) : (
        <a href="/login" class="login-btn">Login / Daftar</a>
      )}
    </div>
  </div>
</nav>

<script>
  // Vanilla JS simpel untuk interaktivitas tombol hamburger
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const navMenu = document.getElementById('nav-menu');

  if (hamburgerBtn && navMenu) {
    hamburgerBtn.addEventListener('click', () => {
      navMenu.classList.toggle('active');
    });
  }
</script>

<style>
  .navbar { background-color: var(--nav-bg); color: var(--text); display: flex; justify-content: space-between; align-items: center; padding: 1.2rem 4rem; position: sticky; top: 0; z-index: 100; border-bottom: 1px solid var(--border); transition: background-color 0.3s; }
  .logo { font-size: 1.8rem; font-weight: 700; letter-spacing: -0.05em; }
  
  .nav-menu { display: flex; gap: 2.5rem; align-items: center; }
  .nav-links { display: flex; gap: 2.5rem; align-items: center; font-weight: 500; font-size: 0.95rem; margin: 0; padding: 0; }
  .nav-links a:hover { opacity: 0.7; }
  .admin-link { background: var(--border); padding: 0.4rem 1rem; border-radius: 999px; font-size: 0.85rem;}
  
  .user-profile { display: flex; align-items: center; gap: 1.5rem; }
  .profile-info { display: flex; align-items: center; gap: 0.8rem; font-weight: 500; }
  .avatar { width: 36px; height: 36px; background: #eee; border-radius: 50%; overflow: hidden; }
  .avatar img { width: 100%; height: 100%; object-fit: cover; }
  .login-btn { font-size: 0.95rem; font-weight: 600; background-color: var(--text); color: var(--bg); padding: 0.6rem 1.5rem; border-radius: 999px; transition: opacity 0.2s; }
  .login-btn:hover { opacity: 0.8; }

  /* Tombol Hamburger disembunyikan di Desktop */
  .hamburger { display: none; background: transparent; border: none; color: var(--text); cursor: pointer; padding: 0.5rem; }

  /* Breakpoint 1024px (Laptop Kecil / Tablet Landscape) */
  @media (max-width: 1024px) {
    .navbar { padding: 1.2rem 2rem; }
  }
  
  /* Breakpoint 768px (Mobile / HP) */
  @media (max-width: 768px) {
    .navbar { padding: 1rem 1.5rem; flex-wrap: wrap; }
    
    /* Munculkan Hamburger */
    .hamburger { display: block; }
    
    /* Sembunyikan menu secara default, ubah jadi tumpukan ke bawah */
    .nav-menu { 
      display: none; 
      width: 100%; 
      flex-direction: column; 
      align-items: flex-start; 
      gap: 1.5rem; 
      padding-top: 1.5rem; 
      margin-top: 1rem; 
      border-top: 1px solid var(--border); 
    }
    
    /* Tampilkan saat tombol diklik (class 'active' ditambahkan via JS) */
    .nav-menu.active { display: flex; } 
    
    .nav-links { flex-direction: column; align-items: flex-start; gap: 1.5rem; width: 100%; }
    .user-profile { width: 100%; justify-content: space-between; border-top: 1px dashed var(--border); padding-top: 1.5rem; }
  }
</style>