---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer-content">
    <h2>Mita.</h2>
    <p>Membaca buku kini lebih mudah, dikonfigurasi sekali, dibaca kapan saja. <br/>Perpustakaan online generasi baru.</p>
    
    <div class="footer-bottom">
      <p class="copyright">&copy; {currentYear} @mediacivitas. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer { 
    background-color: var(--bg-dark); 
    color: var(--text); 
    /* Padding kiri dan kanan diset 2rem (atau sekitar 32px) agar tidak mentok */
    padding: 5rem 2rem 2rem 2rem; 
    margin-top: 5rem; 
    border-top: 1px solid var(--border-muted);
    transition: background-color 0.3s, color 0.3s, border-color 0.3s;
  }
  
  .footer-content { 
    max-width: 1200px; /* Lebar maksimal konten diselaraskan dengan grid buku */
    margin: 0 auto; /* Supaya selalu ada di tengah layar monitor besar */
  }
  
  .footer h2 { 
    font-size: 2.5rem; 
    font-weight: 700; 
    letter-spacing: -0.05em; 
    margin-bottom: 1rem; 
    color: var(--text); 
  }
  
  .footer p { 
    color: var(--text-muted); 
    font-size: 1rem; 
    max-width: 500px; 
    line-height: 1.6;
  }
  
  .footer-bottom { 
    margin-top: 4rem; 
    padding-top: 2rem; 
    border-top: 1px solid var(--border-muted); 
    display: flex; 
    justify-content: space-between; 
    align-items: center; 
  }
  
  .copyright { 
    font-size: 0.85rem !important; 
    color: var(--text-muted); 
    font-weight: 500;
  }

  /* Tambahan untuk layar HP supaya teks tidak terlalu mepet */
  @media (max-width: 768px) {
    .footer {
      padding: 4rem 1.5rem 2rem 1.5rem;
    }
    .footer-bottom {
      flex-direction: column;
      text-align: center;
      gap: 1rem;
    }
  }
</style>