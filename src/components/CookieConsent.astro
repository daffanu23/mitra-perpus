---
// src/components/CookieConsent.astro
// Kita cek apakah server sudah menerima cookie consent dari user
const consentCookie = Astro.cookies.get('mitra-consent')?.value;

// Jika sudah ada keputusan yang valid (accepted/rejected), jangan render HTML banner ini
if (consentCookie === 'accepted' || consentCookie === 'rejected') {
  return null;
}
---

<div id="cookie-banner" class="cookie-consent">
  <div class="cookie-content">
    <p class="cookie-title">🍪 Privasi & Keamanan Anda</p>
    <p class="cookie-desc">
      Kami memerlukan <em>cookies</em> untuk menjalankan fitur penting seperti Login dan Autentikasi. Tanpa persetujuan, Anda tetap bisa menjelajahi koleksi buku.
    </p>
  </div>
  <div class="cookie-actions">
    <button id="reject-cookies" class="cookie-btn reject">Tolak</button>
    <button id="accept-cookies" class="cookie-btn accept">Saya Mengerti</button>
  </div>
</div>

<script>
  // Gunakan window.onload atau delay kecil untuk memastikan transisi terlihat halus
  window.addEventListener('load', () => {
    const banner = document.getElementById('cookie-banner');
    const acceptBtn = document.getElementById('accept-cookies');
    const rejectBtn = document.getElementById('reject-cookies');

    // Munculkan banner dengan jeda sedikit agar tidak "kaget" atau hilang sekejap
    if (banner) {
      setTimeout(() => {
        banner.classList.add('show');
      }, 500);
    }

    function setConsentCookie(value: string) {
      const d = new Date();
      d.setTime(d.getTime() + (30*24*60*60*1000));
      document.cookie = `mitra-consent=${value};expires=${d.toUTCString()};path=/`;
      
      if (banner) {
        banner.classList.remove('show');
      }
      
      setTimeout(() => {
        window.location.reload();
      }, 400);
    }

    if (acceptBtn && rejectBtn) {
      acceptBtn.addEventListener('click', () => setConsentCookie('accepted'));
      rejectBtn.addEventListener('click', () => setConsentCookie('rejected'));
    }
  });
</script>

<style>
  .cookie-consent {
    position: fixed; bottom: 2rem; left: 50%; transform: translateX(-50%) translateY(100px);
    background-color: var(--bg); border: 1px solid var(--border); box-shadow: 0 15px 40px rgba(0,0,0,0.12);
    padding: 1.5rem 2rem; border-radius: 24px; display: flex; align-items: center; justify-content: space-between;
    gap: 2.5rem; z-index: 9999; width: 90%; max-width: 800px; opacity: 0; pointer-events: none;
    transition: transform 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275), opacity 0.6s;
  }
  [data-theme="dark"] .cookie-consent { box-shadow: 0 15px 40px rgba(0,0,0,0.5); }
  
  .cookie-consent.show { transform: translateX(-50%) translateY(0); opacity: 1; pointer-events: auto; }
  
  .cookie-content { flex: 1; }
  .cookie-title { font-weight: 700; color: var(--text); font-size: 1.05rem; margin-bottom: 0.4rem; }
  .cookie-desc { font-size: 0.9rem; color: var(--text-muted); line-height: 1.5; margin: 0; }
  
  .cookie-actions { display: flex; gap: 1rem; }
  .cookie-btn { border: none; padding: 0.8rem 1.8rem; border-radius: 999px; font-weight: 600; font-size: 0.95rem; cursor: pointer; transition: all 0.2s ease; font-family: inherit; white-space: nowrap; }
  .cookie-btn:hover { opacity: 0.8; transform: translateY(-2px); }
  
  .cookie-btn.accept { background-color: var(--text); color: var(--bg); }
  .cookie-btn.reject { background-color: transparent; color: var(--text); border: 1px solid var(--border); }

  @media (max-width: 768px) {
    .cookie-consent { flex-direction: column; align-items: flex-start; bottom: 1rem; padding: 1.5rem; gap: 1.5rem; border-radius: 20px; }
    .cookie-actions { width: 100%; flex-direction: column; }
    .cookie-btn { width: 100%; }
  }
</style>