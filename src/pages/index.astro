---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase.js';

const { data: categories } = await supabase.from('categories').select('*');
const { data: books } = await supabase.from('books').select('*');

// Eksplorasi palet warna yang jauh lebih luas, segar, dan berani
const categoryColors: Record<string, string> = {
  'design': '#FFE1A8',         // Warm Sand / Yellow
  'k3': '#E2F0CB',             // Matcha Green
  'coding': '#C7CEEA',         // Periwinkle / Soft Purple
  'bahasa jepang': '#FFB7B2',  // Salmon Pink
  'bahasa inggris': '#B5EAD7'  // Mint Blue
};
const defaultColor = '#F0F4F8'; // Warna cadangan bersih

const booksByCategory: Record<string, any[]> = {};
if (categories && books) {
  categories.forEach((category: any) => {
    booksByCategory[category.name] = books
      .filter((book: any) => book.category_id === category.id)
      .slice(0, 4); 
  });
}
---

<Layout>
  <section class="section-wrapper">
    <div class="hero cycled-bg">
      <div class="hero-text">
        <h1>Perpustakaan online, <br/>tanpa batasan.</h1>
        <p>Eksplorasi ribuan judul buku dari berbagai kategori. Susun koleksi Anda. Baca kapan saja.</p>
        
        <form action="/search" method="get" class="hero-search">
          <input type="text" name="q" placeholder="Cari judul buku, penulis, atau ISBN..." required />
          <button type="submit" class="cycled-bg btn-text-sync">Cari Buku</button>
        </form>
      </div>
    </div>
  </section>

  <div class="section-wrapper categories-list">
    {categories && categories.map((category: any) => {
      const categoryBooks = booksByCategory[category.name];
      if (!categoryBooks || categoryBooks.length === 0) return null;

      const bgColor = categoryColors[category.name.toLowerCase()] || defaultColor;

      return (
        <section class="category-card" style={`background-color: ${bgColor};`}>
          <div class="catalog-container">
            <div class="category-header">
              <h2>{category.name}</h2>
              <a href={`/kategori/${category.slug}`} class="go-to">Lihat semua &rarr;</a>
            </div>
            
            <div class="book-grid">
              {categoryBooks.map((book: any) => (
                <a href={`/buku/${book.id}`} class="book-card">
                  <div class="card-img-wrapper">
                    <img src={book.cover_url || "https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=300"} alt={`Cover ${book.title}`} />
                  </div>
                  <div class="book-info">
                    <h3>{book.title}</h3>
                    <p>{book.author}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      );
    })}
  </div>

  <section class="section-wrapper">
    <div class="newsletter-card">
      <div class="newsletter-content">
        <h2>Keep track of what we're working on with the Mitra Newsletter.</h2>
        <form class="newsletter-form">
          <input type="email" placeholder="Your email" required />
          <button type="submit">Subscribe</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Global Layout Wrappers */
  .section-wrapper { padding: 0 2rem; max-width: 1400px; margin: 0 auto; }
  
  /* Animasi Color Cycle */
  .cycled-bg {
    animation: smoothColorCycle 10s infinite;
  }
  
  @keyframes smoothColorCycle {
    0%, 15%   { background-color: #FFADAD; } 
    20%, 35%  { background-color: #FFD6A5; } 
    40%, 55%  { background-color: #FDFFB6; } 
    60%, 75%  { background-color: #CAFFBF; } 
    80%, 95%  { background-color: #9BF6FF; } 
    100%      { background-color: #FFADAD; }
  }

  /* Hero Section (Dikunci warnanya) */
  .hero { border: 1px solid var(--border); border-radius: 32px; padding: 6rem 4rem; display: flex; align-items: center; justify-content: flex-start; text-align: left; min-height: 400px; margin-top: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.02); }
  .hero-text { max-width: 750px; color: #111111; } /* Teks selalu hitam */
  .hero h1 { font-size: 3.5rem; font-weight: 700; line-height: 1.1; margin-bottom: 1.5rem; letter-spacing: -0.04em; }
  .hero p { font-size: 1.1rem; margin-bottom: 3rem; opacity: 0.8; max-width: 600px; }
  
  /* Hero Search Box (Dikunci putih) */
  .hero-search { display: flex; background: #ffffff; border: 2px solid rgba(0,0,0,0.1); border-radius: 999px; padding: 0.5rem; max-width: 600px; margin: 0; transition: border-color 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
  .hero-search:focus-within { border-color: #111111; }
  .hero-search input { flex: 1; border: none; outline: none; padding: 0.8rem 1.5rem; font-size: 1rem; font-family: inherit; background: transparent; color: #111111; }
  
  .hero-search button { border: none; padding: 0.8rem 2rem; border-radius: 999px; font-weight: 600; font-size: 1rem; cursor: pointer; transition: opacity 0.2s, transform 0.1s; font-family: inherit; }
  .hero-search button:hover { opacity: 0.8; transform: scale(0.98); }
  .btn-text-sync { color: #111111; } 

  /* Category Sections (Dikunci warnanya) */
  .categories-list { display: flex; flex-direction: column; gap: 3rem; margin-top: 4rem; margin-bottom: 4rem; }
  .category-card { border-radius: 32px; padding: 4rem; color: #111111; } 
  
  .catalog-container { max-width: 1200px; margin: 0 auto; }
  .category-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem; }
  .category-header h2 { font-size: 2.2rem; font-weight: 700; letter-spacing: -0.03em; color: #111111; }
  
  .go-to { font-size: 0.95rem; font-weight: 600; color: #111111; border: 2px solid rgba(0,0,0,0.1); padding: 0.5rem 1.2rem; border-radius: 999px; transition: all 0.2s; background: rgba(255,255,255,0.4); }
  .go-to:hover { border-color: #111111; background: #111111; color: #ffffff; }

  /* Book Grid (Interactive Books) */
  .book-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2.5rem; }
  .book-card { display: flex; flex-direction: column; }
  
  /* Latar gambar buku dikunci semi-transparan putih */
  .card-img-wrapper { aspect-ratio: 2 / 3; border-radius: 12px; overflow: hidden; background-color: rgba(255,255,255,0.5); margin-bottom: 1rem; box-shadow: 0 8px 20px rgba(0,0,0,0.05); transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .book-card:hover .card-img-wrapper { transform: translateY(-8px) scale(1.02); box-shadow: 0 15px 30px rgba(0,0,0,0.15); }
  .card-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  
  .book-info h3 { font-size: 1.1rem; font-weight: 600; line-height: 1.3; margin-bottom: 0.2rem; color: #111111; }
  .book-info p { font-size: 0.9rem; color: #555555; font-weight: 500; }

  /* Newsletter Section (Dikunci warna #f4f4f4 terang) */
  .newsletter-card { background-color: #f4f4f4; border-radius: 32px; padding: 6rem 2rem; text-align: center; margin-bottom: 4rem; }
  .newsletter-content { max-width: 700px; margin: 0 auto; }
  .newsletter-content h2 { font-size: 2.5rem; font-weight: 700; line-height: 1.2; letter-spacing: -0.03em; margin-bottom: 3rem; color: #111111; }
  
  .newsletter-form { display: flex; align-items: flex-end; justify-content: center; gap: 1.5rem; max-width: 500px; margin: 0 auto; }
  .newsletter-form input { flex: 1; border: none; border-bottom: 2px solid rgba(0,0,0,0.2); background: transparent; padding: 0.8rem 0; font-size: 1rem; font-family: inherit; outline: none; color: #111111; border-radius: 0; transition: border-color 0.3s; }
  .newsletter-form input:focus { border-color: #111111; }
  .newsletter-form input::placeholder { color: #888888; }
  .newsletter-form button { background-color: #111111; color: #ffffff; border: none; padding: 0.8rem 2rem; border-radius: 999px; font-weight: 600; font-size: 1rem; cursor: pointer; transition: opacity 0.2s; font-family: inherit; }
  .newsletter-form button:hover { opacity: 0.8; }

  /* Responsivitas */
  @media (max-width: 1024px) { 
    .book-grid { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; } 
    .hero { padding: 4rem 3rem; } 
    .hero h1 { font-size: 2.8rem; } 
    .category-card { padding: 3rem 2rem; }
  }
  @media (max-width: 768px) { 
    .section-wrapper { padding: 0 1rem; }
    .book-grid { grid-template-columns: repeat(2, 1fr); gap: 1rem; } 
    .hero { border-radius: 24px; padding: 3rem 1.5rem; text-align: center; justify-content: center; }
    .hero h1 { font-size: 2.2rem; } 
    .hero p { margin-left: auto; margin-right: auto; }
    .hero-search { flex-direction: column; border: none; box-shadow: none; background: transparent; gap: 1rem; }
    
    .hero-search input { border: 2px solid rgba(0,0,0,0.1); border-radius: 999px; background: #ffffff; width: 100%; color: #111111; }
    .hero-search button { width: 100%; }
    
    .category-card { border-radius: 24px; padding: 2rem 1rem; }
    .categories-list { gap: 2rem; margin-top: 2rem; }
    .category-header h2 { font-size: 1.8rem; }
    
    .newsletter-card { border-radius: 24px; padding: 4rem 1rem; }
    .newsletter-form { flex-direction: column; align-items: stretch; gap: 2rem; }
    .newsletter-form button { width: 100%; }
  }
</style>