---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase.js';

const { data: categories } = await supabase.from('categories').select('*');
const { data: books } = await supabase.from('books').select('*');

const booksByCategory: Record<string, any[]> = {};
if (categories && books) {
  categories.forEach((category: any) => {
    booksByCategory[category.name] = books
      .filter((book: any) => book.category_id === category.id)
      .slice(0, 4); 
  });
}
---

<Layout>
  <section class="section-wrapper">
    <div class="hero">
      <div class="hero-overlay"></div>
      <div class="hero-text">
        <h1>Perpustakaan online, <br/>tanpa batasan.</h1>
        <p>Eksplorasi ribuan judul buku dari berbagai kategori. Susun koleksi Anda. Baca kapan saja.</p>
        
        <form action="/search" method="get" class="hero-search">
          <input type="text" name="q" placeholder="Cari judul buku, penulis, atau ISBN..." required />
          <button type="submit" class="btn-modern">Cari Buku</button>
        </form>
      </div>
    </div>
  </section>

  <div class="section-wrapper categories-list">
    {categories && categories.map((category: any) => {
      const categoryBooks = booksByCategory[category.name];
      if (!categoryBooks || categoryBooks.length === 0) return null;

      return (
        <section class="category-card">
          <div class="catalog-container">
            <div class="category-header">
              <h2>{category.name}</h2>
              <a href={`/kategori/${category.slug}`} class="go-to">Lihat semua &rarr;</a>
            </div>
            
            <div class="book-grid">
              {categoryBooks.map((book: any) => (
                <a href={`/buku/${book.id}`} class="book-card">
                  <div class="card-img-wrapper">
                    <img src={book.cover_url || "https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=300"} alt={`Cover ${book.title}`} />
                  </div>
                  <div class="book-info">
                    <h3>{book.title}</h3>
                    <p>{book.author}</p>
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      );
    })}
  </div>

  <section class="section-wrapper">
    <div class="newsletter-card">
      <div class="newsletter-content">
        <h2>Keep track of what we're working on with the Mitra Newsletter.</h2>
        <form class="newsletter-form">
          <input type="email" placeholder="Your email" required />
          <button type="submit" class="btn-modern">Subscribe</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<style> 
  /* Global Layout Wrappers */
  .section-wrapper { padding: 0 2rem; max-width: 1400px; margin: 0 auto; }
  
  /* --- HERO SECTION --- */
  .hero { 
    position: relative; 
    border-radius: 24px; /* Sudut sedikit dilembutkan */
    padding: 6rem 4rem; 
    display: flex; 
    align-items: center; 
    justify-content: flex-start; 
    text-align: left; 
    min-height: 450px; 
    margin-top: 2rem; 
    /* Hilangkan border, ganti dengan shadow sangat lembut */
    box-shadow: 0 20px 40px color-mix(in oklch, var(--text) 3%, transparent); 
    overflow: hidden;
    background-image: url('/hero_image.jpg'); 
    background-size: cover; 
    background-position: center; 
  }
  
  .hero-overlay { 
    position: absolute; 
    inset: 0; 
    background: linear-gradient(to right, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.4) 50%, transparent 100%); 
    z-index: 1; 
  }
  
  .hero-text { position: relative; z-index: 2; max-width: 750px; color: #ffffff; } 
  .hero h1 { font-size: 4rem; font-weight: 700; line-height: 1.05; margin-bottom: 1rem; letter-spacing: -0.04em; }
  .hero p { font-size: 1.15rem; margin-bottom: 3rem; opacity: 0.85; max-width: 500px; font-weight: 400; }
  
  /* Hero Search Box - CLEAN SAAS STYLE */
  .hero-search { 
    display: flex; 
    background: var(--bg); 
    border: 1px solid color-mix(in oklch, var(--text) 10%, transparent); /* Garis super tipis */
    border-radius: 16px; /* Selaras dengan tombol baru */
    padding: 0.5rem; 
    max-width: 600px; 
    margin: 0; 
    transition: all 0.3s ease; 
    box-shadow: 0 10px 30px rgba(0,0,0,0.1); 
  }
  .hero-search:focus-within { 
    box-shadow: 0 10px 40px rgba(0,0,0,0.2); 
    border-color: color-mix(in oklch, var(--text) 30%, transparent);
  }
  .hero-search input { 
    flex: 1; 
    border: none; 
    outline: none; 
    padding: 0.8rem 1.5rem; 
    font-size: 1rem; 
    font-family: inherit; 
    background: transparent; 
    color: var(--text); 
  }

  /* --- CATEGORY SECTIONS --- */
  .categories-list { display: flex; flex-direction: column; gap: 4rem; margin-top: 5rem; margin-bottom: 5rem; }
  
  /* Hilangkan border pada kategori! Hanya pakai perbedaan warna background */
  .category-card { 
    border-radius: 32px; 
    padding: 5rem 4rem; 
    background-color: var(--bg-light); 
    /* DIBUANG: border: 1px solid var(--border-muted); */
  } 
  
  .catalog-container { max-width: 1200px; margin: 0 auto; }
  .category-header { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 3rem; }
  .category-header h2 { font-size: 2.5rem; font-weight: 700; letter-spacing: -0.04em; color: var(--text); line-height: 1; }
  
  .go-to { 
    font-size: 0.95rem; 
    font-weight: 500; 
    color: var(--text-muted); 
    transition: all 0.2s; 
  }
  .go-to:hover { color: var(--text); }

  /* Book Grid */
  .book-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 3rem 2.5rem; }
  .book-card { display: flex; flex-direction: column; text-decoration: none; }
  
  .card-img-wrapper { 
    aspect-ratio: 2 / 3; 
    border-radius: 8px; /* Lebih kotak seperti buku asli */
    overflow: hidden; 
    background-color: var(--bg); 
    margin-bottom: 1.2rem; 
    /* Shadow lembut tanpa garis tepi */
    box-shadow: 0 10px 25px color-mix(in oklch, var(--text) 5%, transparent); 
    transition: transform 0.4s ease, box-shadow 0.4s ease; 
  }
  .book-card:hover .card-img-wrapper { 
    transform: translateY(-8px); 
    box-shadow: 0 20px 40px color-mix(in oklch, var(--text) 12%, transparent); 
  }
  .card-img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
  
  .book-info h3 { font-size: 1.1rem; font-weight: 600; line-height: 1.4; margin-bottom: 0.3rem; color: var(--text); }
  .book-info p { font-size: 0.9rem; color: var(--text-muted); font-weight: 400; }

  /* --- NEWSLETTER SECTION --- */
  .newsletter-card { 
    background-color: var(--bg); /* Dibuat menyatu dengan background utama */
    border-radius: 24px; 
    padding: 6rem 2rem; 
    text-align: center; 
    margin-bottom: 4rem; 
    /* Shadow lembut */
    box-shadow: 0 10px 50px color-mix(in oklch, var(--text) 3%, transparent);
  }
  .newsletter-content { max-width: 600px; margin: 0 auto; }
  .newsletter-content h2 { font-size: 2.5rem; font-weight: 700; line-height: 1.1; letter-spacing: -0.04em; margin-bottom: 2.5rem; color: var(--text); }
  
  .newsletter-form { display: flex; align-items: center; justify-content: center; gap: 1rem; max-width: 450px; margin: 0 auto; }
  .newsletter-form input { 
    flex: 1; 
    border: 1px solid color-mix(in oklch, var(--text) 15%, transparent); 
    background: transparent; 
    padding: 0.8rem 1.2rem; 
    font-size: 1rem; 
    font-family: inherit; 
    outline: none; 
    color: var(--text); 
    border-radius: 12px; 
    transition: border-color 0.3s; 
  }
  .newsletter-form input:focus { border-color: var(--text); }

  /* Responsivitas */
  @media (max-width: 1024px) { 
    .book-grid { grid-template-columns: repeat(3, 1fr); gap: 2rem; } 
    .hero { padding: 4rem 3rem; } 
    .hero h1 { font-size: 3rem; } 
    .category-card { padding: 4rem 2rem; }
  }
  @media (max-width: 768px) { 
    .section-wrapper { padding: 0 1rem; }
    .book-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem 1rem; } 
    .hero { border-radius: 20px; padding: 4rem 1.5rem; text-align: center; justify-content: center; }
    .hero-overlay { background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.4) 100%); }
    .hero h1 { font-size: 2.5rem; } 
    .hero p { margin-left: auto; margin-right: auto; }
    .hero-search { flex-direction: column; border: none; box-shadow: none; background: transparent; gap: 1rem; }
    
    .hero-search input { border: 1px solid color-mix(in oklch, var(--text) 20%, transparent); border-radius: 12px; background: var(--bg); width: 100%; color: var(--text); }
    .hero-search .btn-modern { width: 100%; }
    
    .category-card { border-radius: 20px; padding: 2rem 1rem; }
    .categories-list { gap: 2rem; margin-top: 2rem; }
    .category-header { flex-direction: column; align-items: flex-start; gap: 1rem; }
    .category-header h2 { font-size: 2rem; }
    
    .newsletter-card { padding: 4rem 1rem; box-shadow: none; border: 1px solid color-mix(in oklch, var(--text) 5%, transparent); }
    .newsletter-form { flex-direction: column; align-items: stretch; gap: 1rem; }
  }
</style>