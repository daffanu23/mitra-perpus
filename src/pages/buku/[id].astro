---
// src/pages/buku/[id].astro
import Layout from '../../layouts/Layout.astro';
import { getSupabaseServer } from '../../lib/supabase.js';

const { id } = Astro.params;

// Inisialisasi Supabase dengan gembok consent
const consent = Astro.cookies.get('mitra-consent')?.value;
let book = null;
let recommendedBooks = [];

if (consent === 'accepted') {
  const supabase = getSupabaseServer(Astro.cookies);

  // 1. Ambil data buku berdasarkan ID
  const { data: fetchedBook } = await supabase
    .from('books')
    .select('*')
    .eq('id', id)
    .single();
  
  book = fetchedBook;

  // 2. Ambil buku acak untuk sidebar
  const { data: fetchedRecs } = await supabase
    .from('books')
    .select('*')
    .neq('id', id)
    .limit(4);
    
  recommendedBooks = fetchedRecs || [];
}

// Fallback data sementara jika database belum diisi
const displayBook = book || {
  id: "demo-1",
  title: "The Design of Everyday Things",
  author: "Don Norman",
  publisher: "-",
  publish_year: "-",
  isbn: "-",
  description: "Buku wajib untuk para desainer. Membahas prinsip-prinsip desain kognitif yang membedakan produk yang mudah digunakan dengan yang membuat frustrasi.",
  price: 0,
  cover_url: "https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=300",
  created_at: "2026-03-09T13:27:15.263Z"
};

const displayRecommendations = recommendedBooks.length > 0 ? recommendedBooks : [
  { id: 2, title: "Ensiklopedia Anak Cerdas : Olahraga", date: "04-02-2026", cover_url: "https://images.unsplash.com/photo-1544947950-fa07a98d237f?auto=format&fit=crop&q=80&w=150" },
  { id: 3, title: "The Domestic Goddess", date: "04-02-2026", cover_url: "https://images.unsplash.com/photo-1589829085413-56de8ae18c73?auto=format&fit=crop&q=80&w=150" },
  { id: 4, title: "One Bullet Away", date: "04-02-2026", cover_url: "https://images.unsplash.com/photo-1614165936126-2ed18e471b3b?auto=format&fit=crop&q=80&w=150" }
];

// Format tanggal
const formattedDate = new Date(displayBook.created_at).toLocaleDateString('id-ID', {
  day: '2-digit', month: 'short', year: 'numeric'
});

// Penentuan Teks Tombol Berdasarkan Harga
const isFree = displayBook.price === 0;
const buttonText = isFree ? "Baca Buku (Gratis)" : "Baca Pratinjau";
---

<Layout>
  <div class="book-hero">
    <div class="hero-overlay"></div>
    <div class="hero-content section-wrapper">
      <h1>{displayBook.title}</h1>
      <p class="breadcrumb"><a href="/">Home</a> / <a href="/search">Buku</a> / <strong>{displayBook.title}</strong></p>
    </div>
  </div>

  <div class="book-container section-wrapper">
    <div class="book-layout">
      
      <div class="main-content">
        
        <div class="cover-action-wrapper">
          <div class="cover-image">
            <img src={displayBook.cover_url} alt={`Cover ${displayBook.title}`} />
          </div>
          
          <div class="action-bar">
            <a href={`/baca/${displayBook.id}`} class="btn-modern read-btn">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
              {buttonText}
            </a>
            
            <div class="action-info">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              <span>Diunggah {formattedDate}</span>
            </div>
            
            <button class="btn-icon-round save-btn" title="Simpan ke Pustakaku">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"></path></svg>
            </button>
          </div>
        </div>

        <div class="detail-section">
          <h2>Informasi Buku</h2>
          <div class="info-list">
            <div class="info-item">
              <span class="info-label">Judul Asli</span>
              <span class="info-value font-semibold">{displayBook.title}</span>
            </div>
            <div class="info-item">
              <span class="info-label">Penulis</span>
              <span class="info-value">{displayBook.author || '-'}</span>
            </div>
            <div class="info-item">
              <span class="info-label">Penerbit</span>
              <span class="info-value">{displayBook.publisher || '-'}</span>
            </div>
            <div class="info-item">
              <span class="info-label">Tahun Terbit</span>
              <span class="info-value">{displayBook.publish_year || '-'}</span>
            </div>
            <div class="info-item">
              <span class="info-label">ISBN</span>
              <span class="info-value">{displayBook.isbn || '-'}</span>
            </div>
            <div class="info-item description-item">
              <span class="info-label">Uraian Buku</span>
              <span class="info-value leading-relaxed">{displayBook.description || 'Tidak ada deskripsi yang tersedia untuk buku ini.'}</span>
            </div>
          </div>
        </div>
      </div>

      <aside class="sidebar">
        <div class="sidebar-card">
          <form action="/search" class="sidebar-search">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
            <input type="text" name="q" placeholder="Cari buku lain..." />
          </form>

          <h3 class="sidebar-title">Rekomendasi</h3>
          <div class="recommendation-list">
            {displayRecommendations.map((rec) => (
              <a href={`/buku/${rec.id}`} class="rec-item">
                <img src={rec.cover_url} alt={`Cover ${rec.title}`} />
                <div class="rec-info">
                  <h4>{rec.title}</h4>
                  <p>{rec.author || "Penulis Tidak Diketahui"}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
      </aside>

    </div>
  </div>
</Layout>

<style>
  /* Global Layout */
  .section-wrapper { padding: 0 2rem; max-width: 1400px; margin: 0 auto; }
  
  /* Hero Banner Minimalis */
  .book-hero { 
    position: relative; 
    padding: 6rem 0 4rem 0; 
    background-color: var(--bg-dark); 
    overflow: hidden; 
    text-align: center; 
  }

  .hero-overlay { 
    position: absolute; 
    top: 0; left: 0; right: 0; bottom: 0; 
    background: radial-gradient(circle at center, rgba(255,255,255,0.05) 0%, transparent 70%); 
    pointer-events: none; 
  }
  
  .hero-content { position: relative; z-index: 10; }
  .hero-content h1 { font-size: 3rem; font-weight: 700; margin-bottom: 1rem; letter-spacing: -0.03em; color: var(--text); }
  .breadcrumb { font-size: 0.95rem; color: var(--text-muted); }
  .breadcrumb a { transition: color 0.2s; }
  .breadcrumb a:hover { color: var(--text); }
  .breadcrumb strong { font-weight: 600; color: var(--text); }

  /* Grid Layout */
  .book-container { margin-top: 4rem; padding-bottom: 6rem; }
  .book-layout { display: grid; grid-template-columns: 1fr 350px; gap: 5rem; align-items: start; }

  /* --- SISI KIRI --- */
  .main-content { display: flex; flex-direction: column; gap: 4rem; }
  
  /* Cover Wrapper (Tanpa Border) */
  .cover-action-wrapper { 
    background-color: var(--bg-light); 
    padding: 3rem; 
    border-radius: 32px; 
    box-shadow: 0 10px 40px color-mix(in oklch, var(--text) 3%, transparent);
  }
  
  .cover-image { 
    width: 100%; 
    max-width: 320px; 
    aspect-ratio: 2/3; 
    margin: 0 auto 3rem auto; 
    border-radius: 12px; 
    overflow: hidden; 
    box-shadow: 0 20px 50px color-mix(in oklch, var(--text) 8%, transparent); 
  }
  .cover-image img { width: 100%; height: 100%; object-fit: cover; display: block; }
  
  /* Action Bar Modern */
  .action-bar { 
    display: flex; 
    align-items: center; 
    justify-content: space-between; 
    gap: 1.5rem; 
    border-top: 1px solid color-mix(in oklch, var(--text) 10%, transparent); 
    padding-top: 2rem; 
  }
  
  .read-btn { flex: 1; justify-content: center; padding: 1rem 2rem; font-size: 1rem; }
  
  .action-info { 
    display: flex; 
    align-items: center; 
    gap: 0.5rem; 
    font-size: 0.85rem; 
    color: var(--text-muted); 
    font-weight: 500; 
  }
  .action-info svg { color: var(--text-muted); }
  
  .save-btn { width: 48px; height: 48px; flex-shrink: 0; }

  /* Informasi Buku (List Modern pengganti Tabel Kaku) */
  .detail-section h2 { font-size: 1.8rem; font-weight: 700; letter-spacing: -0.03em; margin-bottom: 2rem; color: var(--text); }
  
  .info-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .info-item { display: grid; grid-template-columns: 180px 1fr; gap: 1rem; align-items: baseline; }
  .description-item { display: flex; flex-direction: column; gap: 0.8rem; margin-top: 1rem; }
  
  .info-label { font-size: 0.95rem; font-weight: 600; color: var(--text-muted); }
  .info-value { font-size: 1rem; color: var(--text); }
  
  .font-semibold { font-weight: 600; font-size: 1.1rem; }
  .leading-relaxed { line-height: 1.7; color: var(--text-muted); }

  /* --- SISI KANAN (Sidebar) --- */
  .sidebar { position: sticky; top: 120px; }
  
  .sidebar-card { 
    background-color: var(--bg); 
    border-radius: 24px; 
    padding: 2.5rem 2rem; 
    border: 1px solid color-mix(in oklch, var(--text) 8%, transparent);
    box-shadow: 0 10px 30px color-mix(in oklch, var(--text) 2%, transparent);
  }
  
  .sidebar-search { 
    display: flex; 
    align-items: center; 
    gap: 0.8rem; 
    background-color: var(--bg-light); 
    border: 1px solid color-mix(in oklch, var(--text) 10%, transparent); 
    padding: 0.8rem 1.2rem; 
    border-radius: 12px; 
    margin-bottom: 2.5rem; 
    transition: border-color 0.3s; 
  }
  .sidebar-search:focus-within { border-color: var(--text); }
  .sidebar-search svg { color: var(--text-muted); }
  .sidebar-search input { flex: 1; border: none; background: transparent; outline: none; color: var(--text); font-family: inherit; font-size: 0.95rem; }
  
  .sidebar-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 1.5rem; color: var(--text); }

  .recommendation-list { display: flex; flex-direction: column; gap: 1.5rem; }
  .rec-item { display: flex; gap: 1rem; align-items: center; border-radius: 12px; transition: opacity 0.2s, transform 0.2s; }
  .rec-item:hover { opacity: 0.8; transform: translateX(4px); }
  
  .rec-item img { width: 65px; aspect-ratio: 2/3; object-fit: cover; border-radius: 8px; box-shadow: 0 4px 10px color-mix(in oklch, var(--text) 5%, transparent); }
  .rec-info h4 { font-size: 0.95rem; font-weight: 600; color: var(--text); margin-bottom: 0.3rem; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
  .rec-info p { font-size: 0.8rem; color: var(--text-muted); }

  /* Responsivitas */
  @media (max-width: 1024px) {
    .book-layout { grid-template-columns: 1fr 300px; gap: 3rem; }
    .book-hero { padding: 5rem 0 4rem 0; }
    .hero-content h1 { font-size: 2.5rem; }
  }
  
  @media (max-width: 768px) {
    .book-layout { grid-template-columns: 1fr; margin-top: -2rem; gap: 4rem;}
    .book-hero { padding: 4rem 0 4rem 0; }
    .hero-content h1 { font-size: 2rem; }
    
    .cover-action-wrapper { padding: 2rem 1.5rem; border-radius: 24px; }
    
    .action-bar { flex-direction: column; align-items: stretch; gap: 1rem; }
    .read-btn { width: 100%; }
    .action-info { justify-content: center; order: 3; margin-top: 0.5rem; }
    .save-btn { width: 100%; border-radius: 12px; }
    
    .info-item { grid-template-columns: 1fr; gap: 0.3rem; margin-bottom: 1rem; }
    .info-label { font-size: 0.85rem; }
    
    .sidebar { position: static; }
  }
</style>