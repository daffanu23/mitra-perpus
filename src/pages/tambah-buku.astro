---
// src/pages/tambah-buku.astro
import Layout from '../layouts/Layout.astro';
import { getSupabaseServer } from '../lib/supabase.js';

const supabase = getSupabaseServer(Astro.cookies);

// 1. GEMBOK KEAMANAN: Pastikan yang masuk BENAR-BENAR ADMIN
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase.from('profiles').select('role').eq('id', user.id).single();
if (profile?.role !== 'admin') {
  return Astro.redirect('/'); // Tendang ke beranda kalau bukan admin!
}

// 2. Ambil daftar kategori yang sudah ada
const { data: categories } = await supabase.from('categories').select('*').order('name');

let errorMessage = '';
let successMessage = '';

// 3. TANGKAP DATA SAAT FORM DISUBMIT
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    // Ambil input teks
    const title = formData.get('title')?.toString();
    const author = formData.get('author')?.toString();
    const publisher = formData.get('publisher')?.toString();
    const publish_year = formData.get('publish_year')?.toString();
    const isbn = formData.get('isbn')?.toString();
    const description = formData.get('description')?.toString();
    const price = parseFloat(formData.get('price')?.toString() || '0');
    
    let category_id = formData.get('category_id')?.toString();
    const new_category_name = formData.get('new_category_name')?.toString();

    // --- LOGIKA KATEGORI BARU ---
    if (category_id === 'new' && new_category_name) {
      const slug = new_category_name.toLowerCase().replace(/[^a-z0-9]+/g, '-');
      const { data: newCat, error: catError } = await supabase
        .from('categories')
        .insert([{ name: new_category_name, slug }])
        .select()
        .single();
        
      if (catError) throw new Error("Gagal membuat kategori baru.");
      category_id = newCat.id; // Gunakan ID kategori yang baru saja dibuat
    }

    // --- LOGIKA UPLOAD FILE KE STORAGE ---
    const coverFile = formData.get('cover_image') as File;
    const previewPdfFile = formData.get('pdf_preview') as File;
    const fullPdfFile = formData.get('pdf_full') as File;

    let cover_url = null;
    let pdf_preview_url = null;
    let pdf_full_url = null;

    // Fungsi pembantu untuk upload file
    const uploadFile = async (file: File, bucket: string, folder: string) => {
      if (file && file.size > 0) {
        const fileExt = file.name.split('.').pop();
        const fileName = `${folder}/${Date.now()}-${Math.random().toString(36).substring(7)}.${fileExt}`;
        const { error } = await supabase.storage.from(bucket).upload(fileName, file);
        if (error) throw error;
        return supabase.storage.from(bucket).getPublicUrl(fileName).data.publicUrl;
      }
      return null;
    };

    cover_url = await uploadFile(coverFile, 'covers', 'images');
    pdf_preview_url = await uploadFile(previewPdfFile, 'pdfs', 'preview');
    pdf_full_url = await uploadFile(fullPdfFile, 'pdfs', 'full');

    // --- MASUKKAN SEMUA DATA KE TABEL BOOKS ---
    const { error: insertError } = await supabase.from('books').insert([{
      title, author, publisher, publish_year, isbn, description, price, category_id,
      cover_url, pdf_preview_url, pdf_full_url
    }]);

    if (insertError) throw insertError;
    successMessage = `Buku "${title}" berhasil ditambahkan ke perpustakaan!`;
    
  } catch (error: any) {
    errorMessage = error.message || "Terjadi kesalahan saat mengunggah buku.";
  }
}
---

<Layout>
  <div class="admin-page section-wrapper">
    <div class="admin-header">
      <h1>Tambah Koleksi Baru</h1>
      <p>Unggah detail buku beserta file PDF Pratinjau dan Full untuk pembaca.</p>
    </div>

    {errorMessage && <div class="alert error">{errorMessage}</div>}
    {successMessage && <div class="alert success">{successMessage}</div>}

    <form method="POST" enctype="multipart/form-data" class="admin-form">
      
      <div class="form-grid">
        <div class="input-group">
          <label for="title">Judul Buku *</label>
          <input type="text" id="title" name="title" required placeholder="Cth: Figma untuk Pemula" />
        </div>
        
        <div class="input-group">
          <label for="author">Nama Penulis *</label>
          <input type="text" id="author" name="author" required placeholder="Cth: Daniel Fick" />
        </div>

        <div class="input-group">
          <label for="publisher">Penerbit</label>
          <input type="text" id="publisher" name="publisher" placeholder="Cth: PT Mediacivitas" />
        </div>

        <div class="input-group">
          <label for="publish_year">Tahun Terbit</label>
          <input type="number" id="publish_year" name="publish_year" placeholder="Cth: 2026" />
        </div>

        <div class="input-group">
          <label for="isbn">ISBN</label>
          <input type="text" id="isbn" name="isbn" placeholder="Cth: 978-602-..." />
        </div>

        <div class="input-group">
          <label for="price">Harga (Rp) *</label>
          <input type="number" id="price" name="price" required value="0" min="0" />
          <small>Isi 0 jika buku ini gratis.</small>
        </div>
      </div>

      <div class="category-section">
        <div class="input-group">
          <label for="category_id">Kategori Buku *</label>
          <select id="category_id" name="category_id" required>
            <option value="" disabled selected>Pilih Kategori...</option>
            {categories?.map(cat => (
              <option value={cat.id}>{cat.name}</option>
            ))}
            <option value="new" class="highlight-option">+ Buat Kategori Baru...</option>
          </select>
        </div>
        
        <div class="input-group hidden" id="new-category-wrapper">
          <label for="new_category_name">Nama Kategori Baru *</label>
          <input type="text" id="new_category_name" name="new_category_name" placeholder="Ketik kategori baru di sini..." />
        </div>
      </div>

      <div class="input-group full-width">
        <label for="description">Uraian / Sinopsis Singkat</label>
        <textarea id="description" name="description" rows="4" placeholder="Ceritakan sekilas tentang isi buku ini..."></textarea>
      </div>

      <div class="file-upload-section">
        <h3>Berkas Buku</h3>
        <div class="file-grid">
          <div class="file-card">
            <label for="cover_image">Sampul Buku (Gambar) *</label>
            <input type="file" id="cover_image" name="cover_image" accept="image/png, image/jpeg, image/webp" required />
          </div>
          
          <div class="file-card">
            <label for="pdf_preview">PDF Pratinjau (Opsional)</label>
            <input type="file" id="pdf_preview" name="pdf_preview" accept="application/pdf" />
            <small>Cth: File PDF yang hanya berisi Bab 1.</small>
          </div>

          <div class="file-card highlight-card">
            <label for="pdf_full">PDF Full (Wajib) *</label>
            <input type="file" id="pdf_full" name="pdf_full" accept="application/pdf" required />
            <small>Buku utuh yang aman di database.</small>
          </div>
        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="submit-btn primary-submit">Unggah Buku ke Sistem</button>
      </div>

    </form>
  </div>
</Layout>

<script>
  // Logika untuk memunculkan input Kategori Baru
  document.addEventListener('DOMContentLoaded', () => {
    const categorySelect = document.getElementById('category_id') as HTMLSelectElement;
    const newCategoryWrapper = document.getElementById('new-category-wrapper');
    const newCategoryInput = document.getElementById('new_category_name') as HTMLInputElement;

    if (categorySelect && newCategoryWrapper && newCategoryInput) {
      categorySelect.addEventListener('change', (e) => {
        if ((e.target as HTMLSelectElement).value === 'new') {
          newCategoryWrapper.classList.remove('hidden');
          newCategoryInput.required = true;
          newCategoryInput.focus();
        } else {
          newCategoryWrapper.classList.add('hidden');
          newCategoryInput.required = false;
        }
      });
    }
  });
</script>

<style>
  .admin-page { padding: 4rem 2rem 8rem 2rem; max-width: 900px; margin: 0 auto; }
  
  .admin-header { margin-bottom: 3rem; text-align: center; }
  .admin-header h1 { font-size: 2.5rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; letter-spacing: -0.03em; }
  .admin-header p { color: var(--text-muted); font-size: 1rem; }

  /* Alerts */
  .alert { padding: 1rem; border-radius: 16px; margin-bottom: 2rem; font-weight: 500; text-align: center; }
  .alert.error { background-color: #ffeaea; color: #d32f2f; border: 1px solid #ffcdd2; }
  .alert.success { background-color: #e8f5e9; color: #2e7d32; border: 1px solid #c8e6c9; }
  [data-theme="dark"] .alert.error { background-color: rgba(211, 47, 47, 0.2); border-color: rgba(211, 47, 47, 0.5); color: #ff8a80; }
  [data-theme="dark"] .alert.success { background-color: rgba(46, 125, 50, 0.2); border-color: rgba(46, 125, 50, 0.5); color: #81c784; }

  /* Form Layout */
  .admin-form { display: flex; flex-direction: column; gap: 2.5rem; background-color: var(--bg-section); padding: 3rem; border-radius: 32px; border: 1px solid var(--border); }
  
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .category-section { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; background-color: var(--bg); padding: 1.5rem; border-radius: 20px; border: 1px dashed var(--border); }
  
  .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .input-group.full-width { grid-column: 1 / -1; }
  .input-group.hidden { display: none; }
  
  .input-group label { font-size: 0.9rem; font-weight: 600; color: var(--text); }
  .input-group input, .input-group select, .input-group textarea { padding: 1rem 1.2rem; border-radius: 16px; border: 2px solid var(--border); background-color: var(--bg); color: var(--text); font-family: inherit; font-size: 0.95rem; transition: border-color 0.3s; outline: none; width: 100%; }
  .input-group input:focus, .input-group select:focus, .input-group textarea:focus { border-color: var(--text); }
  .input-group textarea { resize: vertical; min-height: 120px; }
  .input-group small { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.2rem; }
  
  .highlight-option { font-weight: 700; color: var(--primary); }

  /* File Upload Area */
  .file-upload-section { border-top: 1px solid var(--border); padding-top: 2rem; }
  .file-upload-section h3 { margin-bottom: 1.5rem; font-size: 1.2rem; color: var(--text); }
  .file-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; }
  
  .file-card { display: flex; flex-direction: column; gap: 0.5rem; background-color: var(--bg); padding: 1.5rem; border-radius: 20px; border: 1px solid var(--border); }
  .file-card label { font-weight: 600; font-size: 0.9rem; color: var(--text); }
  .file-card input[type="file"] { font-size: 0.85rem; color: var(--text-muted); }
  .file-card input[type="file"]::file-selector-button { background-color: var(--bg-section); color: var(--text); border: 1px solid var(--border); padding: 0.5rem 1rem; border-radius: 8px; cursor: pointer; margin-right: 1rem; font-weight: 600; transition: all 0.2s; }
  .file-card input[type="file"]::file-selector-button:hover { background-color: var(--text); color: var(--bg); }
  .file-card small { font-size: 0.75rem; color: var(--text-muted); }
  
  .highlight-card { border: 2px solid var(--text); }

  /* Submit Button */
  .form-actions { display: flex; justify-content: flex-end; margin-top: 1rem; }
  .submit-btn { background-color: var(--text); color: var(--bg); border: none; padding: 1.2rem 3rem; border-radius: 999px; font-weight: 600; font-size: 1.05rem; cursor: pointer; transition: opacity 0.2s, transform 0.1s; font-family: inherit; }
  .submit-btn:hover { opacity: 0.8; transform: scale(0.98); }

  /* Responsivitas */
  @media (max-width: 768px) {
    .admin-form { padding: 2rem 1.5rem; border-radius: 24px; }
    .form-grid, .category-section { grid-template-columns: 1fr; }
    .submit-btn { width: 100%; }
  }
</style>