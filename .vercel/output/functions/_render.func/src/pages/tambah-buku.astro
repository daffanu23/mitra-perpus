---
// src/pages/tambah-buku.astro
import Layout from '../layouts/Layout.astro';
import { getSupabaseServer } from '../lib/supabase.js';

const supabase = getSupabaseServer(Astro.cookies);

// 1. GEMBOK KEAMANAN: Pastikan yang masuk BENAR-BENAR ADMIN
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const { data: profile } = await supabase.from('profiles').select('role').eq('id', user.id).single();
if (profile?.role !== 'admin') {
  return Astro.redirect('/'); // Tendang ke beranda kalau bukan admin!
}

// 2. Ambil daftar kategori yang sudah ada
const { data: categories } = await supabase.from('categories').select('*').order('name');

let errorMessage = '';
let successMessage = '';

// 3. TANGKAP DATA SAAT FORM DISUBMIT
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    
    // Ambil input teks
    const title = formData.get('title')?.toString();
    const author = formData.get('author')?.toString();
    const publisher = formData.get('publisher')?.toString();
    const publish_year = formData.get('publish_year')?.toString();
    const isbn = formData.get('isbn')?.toString();
    const description = formData.get('description')?.toString();
    const price = parseFloat(formData.get('price')?.toString() || '0');
    
    let category_id = formData.get('category_id')?.toString();
    const new_category_name = formData.get('new_category_name')?.toString();

    // --- LOGIKA KATEGORI BARU ---
    if (category_id === 'new' && new_category_name) {
      const slug = new_category_name.toLowerCase().replace(/[^a-z0-9]+/g, '-');
      const { data: newCat, error: catError } = await supabase
        .from('categories')
        .insert([{ name: new_category_name, slug }])
        .select()
        .single();
        
      // TAMPILKAN ERROR ASLI DARI SUPABASE JIKA GAGAL (Biasanya karena RLS)
      if (catError) {
        console.error("Supabase Category Error:", catError);
        throw new Error(`Gagal menambah kategori: ${catError.message || catError.details}`);
      }
      
      category_id = newCat.id; // Gunakan ID kategori yang baru saja dibuat
    }

    // --- LOGIKA UPLOAD FILE KE STORAGE ---
    const coverFile = formData.get('cover_image') as File;
    const previewPdfFile = formData.get('pdf_preview') as File;
    const fullPdfFile = formData.get('pdf_full') as File;

    let cover_url = null;
    let pdf_preview_url = null;
    let pdf_full_url = null;

    // Fungsi pembantu untuk upload file
    const uploadFile = async (file: File, bucket: string, folder: string) => {
      if (file && file.size > 0) {
        const fileExt = file.name.split('.').pop();
        const fileName = `${folder}/${Date.now()}-${Math.random().toString(36).substring(7)}.${fileExt}`;
        const { error } = await supabase.storage.from(bucket).upload(fileName, file);
        if (error) throw error;
        return supabase.storage.from(bucket).getPublicUrl(fileName).data.publicUrl;
      }
      return null;
    };

    cover_url = await uploadFile(coverFile, 'covers', 'images');
    pdf_preview_url = await uploadFile(previewPdfFile, 'pdfs', 'preview');
    pdf_full_url = await uploadFile(fullPdfFile, 'pdfs', 'full');

    // --- MASUKKAN SEMUA DATA KE TABEL BOOKS ---
    const { error: insertError } = await supabase.from('books').insert([{
      title, author, publisher, publish_year, isbn, description, price, category_id,
      cover_url, pdf_preview_url, pdf_full_url
    }]);

    if (insertError) throw insertError;
    successMessage = `Buku "${title}" berhasil ditambahkan ke perpustakaan!`;
    
  } catch (error: any) {
    errorMessage = error.message || "Terjadi kesalahan saat mengunggah buku.";
  }
}
---

<Layout>
  <div class="admin-page section-wrapper">
    <div class="admin-header">
      <h1>Tambah Koleksi Baru</h1>
      <p>Unggah detail buku beserta file PDF Pratinjau dan Full untuk pembaca.</p>
    </div>

    {errorMessage && <div class="alert error">{errorMessage}</div>}
    {successMessage && <div class="alert success">{successMessage}</div>}

    <form method="POST" enctype="multipart/form-data" class="admin-form">
      
      <div class="form-grid">
        <div class="input-group">
          <label for="title">Judul Buku *</label>
          <input type="text" id="title" name="title" required placeholder="Cth: Figma untuk Pemula" />
        </div>
        
        <div class="input-group">
          <label for="author">Nama Penulis *</label>
          <input type="text" id="author" name="author" required placeholder="Cth: Daniel Fick" />
        </div>

        <div class="input-group">
          <label for="publisher">Penerbit</label>
          <input type="text" id="publisher" name="publisher" placeholder="Cth: PT Mediacivitas" />
        </div>

        <div class="input-group">
          <label for="publish_year">Tahun Terbit</label>
          <input type="number" id="publish_year" name="publish_year" placeholder="Cth: 2026" />
        </div>

        <div class="input-group">
          <label for="isbn">ISBN</label>
          <input type="text" id="isbn" name="isbn" placeholder="Cth: 978-602-..." />
        </div>

        <div class="input-group">
          <label for="price">Harga (Rp) *</label>
          <input type="number" id="price" name="price" required value="0" min="0" />
          <small>Isi 0 jika buku ini gratis.</small>
        </div>
      </div>

      <div class="category-section">
        <div class="input-group">
          <label for="category_id">Kategori Buku *</label>
          <select id="category_id" name="category_id" required>
            <option value="" disabled selected>Pilih Kategori...</option>
            {categories?.map((cat: any) => (
              <option value={cat.id}>{cat.name}</option>
            ))}
            <option value="new" class="highlight-option">+ Buat Kategori Baru...</option>
          </select>
        </div>
        
        <div class="input-group hidden" id="new-category-wrapper">
          <label for="new_category_name">Nama Kategori Baru *</label>
          <input type="text" id="new_category_name" name="new_category_name" placeholder="Ketik kategori baru di sini..." />
        </div>
      </div>

      <div class="input-group full-width">
        <label for="description">Uraian / Sinopsis Singkat</label>
        <textarea id="description" name="description" rows="4" placeholder="Ceritakan sekilas tentang isi buku ini..."></textarea>
      </div>

      <div class="file-upload-section">
        <h3>Berkas Buku</h3>
        <div class="file-grid">
          
          <div class="file-card" id="card-cover">
            <span class="file-label-title">Sampul Buku (Gambar) *</span>
            <label for="cover_image" class="custom-file-upload">
              <div class="upload-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
              </div>
              <span class="upload-text">Klik untuk memilih</span>
              <span class="file-name" id="name-cover">Belum ada file</span>
            </label>
            <input type="file" id="cover_image" name="cover_image" accept="image/png, image/jpeg, image/webp" class="hidden-input" required />
          </div>
          
          <div class="file-card" id="card-preview">
            <span class="file-label-title">PDF Pratinjau (Opsional)</span>
            <label for="pdf_preview" class="custom-file-upload">
              <div class="upload-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
              </div>
              <span class="upload-text">Klik untuk memilih</span>
              <span class="file-name" id="name-preview">Belum ada file</span>
            </label>
            <input type="file" id="pdf_preview" name="pdf_preview" accept="application/pdf" class="hidden-input" />
          </div>

          <div class="file-card highlight-card" id="card-full">
            <span class="file-label-title">PDF Full (Wajib) *</span>
            <label for="pdf_full" class="custom-file-upload">
              <div class="upload-icon">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>
              </div>
              <span class="upload-text">Klik untuk memilih</span>
              <span class="file-name" id="name-full">Belum ada file</span>
            </label>
            <input type="file" id="pdf_full" name="pdf_full" accept="application/pdf" class="hidden-input" required />
          </div>

        </div>
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-modern">Unggah Buku ke Sistem</button>
      </div>

    </form>
  </div>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // 1. Logika Kategori Baru
    const categorySelect = document.getElementById('category_id') as HTMLSelectElement;
    const newCategoryWrapper = document.getElementById('new-category-wrapper');
    const newCategoryInput = document.getElementById('new_category_name') as HTMLInputElement;

    if (categorySelect && newCategoryWrapper && newCategoryInput) {
      categorySelect.addEventListener('change', (e) => {
        if ((e.target as HTMLSelectElement).value === 'new') {
          newCategoryWrapper.classList.remove('hidden');
          newCategoryInput.required = true;
          newCategoryInput.focus();
        } else {
          newCategoryWrapper.classList.add('hidden');
          newCategoryInput.required = false;
        }
      });
    }

    // 2. Logika Afirmasi File Upload
    const fileInputs = [
      { inputId: 'cover_image', cardId: 'card-cover', nameId: 'name-cover' },
      { inputId: 'pdf_preview', cardId: 'card-preview', nameId: 'name-preview' },
      { inputId: 'pdf_full', cardId: 'card-full', nameId: 'name-full' }
    ];

    // Icon Centang SVG
    const checkIconSVG = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>`;

    fileInputs.forEach(item => {
      const inputEl = document.getElementById(item.inputId) as HTMLInputElement;
      const cardEl = document.getElementById(item.cardId);
      const nameEl = document.getElementById(item.nameId);
      
      if (inputEl && cardEl && nameEl) {
        inputEl.addEventListener('change', (e) => {
          const target = e.target as HTMLInputElement;
          const iconContainer = cardEl.querySelector('.upload-icon');
          
          if (target.files && target.files.length > 0) {
            // File berhasil dipilih
            const fileName = target.files[0].name;
            nameEl.textContent = fileName;
            cardEl.classList.add('has-file');
            
            if (iconContainer) {
              iconContainer.innerHTML = checkIconSVG;
              iconContainer.classList.add('success-icon');
            }
          } else {
            // File batal dipilih
            nameEl.textContent = 'Belum ada file';
            cardEl.classList.remove('has-file');
            
            // Kembalikan ke icon upload default
            if (iconContainer) {
              iconContainer.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="17 8 12 3 7 8"></polyline><line x1="12" y1="3" x2="12" y2="15"></line></svg>`;
              iconContainer.classList.remove('success-icon');
            }
          }
        });
      }
    });
  });
</script>

<style>
  .admin-page { padding: 4rem 2rem 8rem 2rem; max-width: 900px; margin: 0 auto; }
  
  .admin-header { margin-bottom: 3rem; text-align: center; }
  .admin-header h1 { font-size: 2.5rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; letter-spacing: -0.03em; }
  .admin-header p { color: var(--text-muted); font-size: 1rem; }

  /* Alerts */
  .alert { padding: 1rem; border-radius: 16px; margin-bottom: 2rem; font-weight: 500; text-align: center; }
  .alert.error { background-color: color-mix(in oklch, var(--danger) 15%, transparent); color: var(--danger); border: 1px solid color-mix(in oklch, var(--danger) 30%, transparent); }
  .alert.success { background-color: color-mix(in oklch, var(--success) 15%, transparent); color: var(--success); border: 1px solid color-mix(in oklch, var(--success) 30%, transparent); }

  /* Form Layout Clean SaaS */
  .admin-form { display: flex; flex-direction: column; gap: 2.5rem; background-color: var(--bg); padding: 3.5rem; border-radius: 32px; box-shadow: 0 10px 40px color-mix(in oklch, var(--text) 3%, transparent); border: 1px solid color-mix(in oklch, var(--text) 5%, transparent); }
  
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .category-section { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; background-color: var(--bg-light); padding: 1.5rem; border-radius: 20px; border: 1px solid color-mix(in oklch, var(--text) 5%, transparent); }
  
  .input-group { display: flex; flex-direction: column; gap: 0.5rem; }
  .input-group.full-width { grid-column: 1 / -1; }
  .input-group.hidden { display: none; }
  
  .input-group label { font-size: 0.9rem; font-weight: 600; color: var(--text); }
  .input-group input, .input-group select, .input-group textarea { padding: 1rem 1.2rem; border-radius: 12px; border: 1px solid color-mix(in oklch, var(--text) 15%, transparent); background-color: transparent; color: var(--text); font-family: inherit; font-size: 0.95rem; transition: all 0.3s; outline: none; width: 100%; }
  .input-group input:focus, .input-group select:focus, .input-group textarea:focus { border-color: var(--text); box-shadow: 0 0 0 4px color-mix(in oklch, var(--text) 5%, transparent); }
  .input-group textarea { resize: vertical; min-height: 120px; }
  .input-group small { font-size: 0.8rem; color: var(--text-muted); margin-top: 0.2rem; }
  
  .highlight-option { font-weight: 700; color: var(--text); }

  /* UPLOAD AREA UX */
  .file-upload-section { border-top: 1px solid color-mix(in oklch, var(--text) 10%, transparent); padding-top: 2.5rem; }
  .file-upload-section h3 { margin-bottom: 1.5rem; font-size: 1.2rem; color: var(--text); }
  .file-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; }
  
  .file-card { display: flex; flex-direction: column; gap: 0.8rem; }
  .file-label-title { font-weight: 600; font-size: 0.9rem; color: var(--text); }
  
  .hidden-input { display: none; }
  
  .custom-file-upload { display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 2rem 1rem; border-radius: 16px; border: 2px dashed color-mix(in oklch, var(--text) 20%, transparent); background-color: var(--bg-light); cursor: pointer; transition: all 0.3s ease; height: 100%; min-height: 160px; }
  .custom-file-upload:hover { border-color: var(--text); background-color: color-mix(in oklch, var(--text) 2%, var(--bg)); }
  
  .upload-icon { color: var(--text-muted); margin-bottom: 0.8rem; transition: color 0.3s; }
  .upload-icon.success-icon { color: var(--success); }
  
  .upload-text { font-weight: 600; font-size: 0.9rem; color: var(--text); margin-bottom: 0.4rem; }
  .file-name { font-size: 0.8rem; color: var(--text-muted); word-break: break-all; max-width: 90%; line-height: 1.4; }
  
  .file-card.has-file .custom-file-upload { border: 2px solid var(--success); background-color: color-mix(in oklch, var(--success) 5%, transparent); }
  .file-card.has-file .upload-text { color: var(--success); }
  .file-card.has-file .file-name { color: var(--text); font-weight: 500; }

  .highlight-card .custom-file-upload { border-color: color-mix(in oklch, var(--primary) 40%, transparent); }

  .form-actions { display: flex; justify-content: flex-end; margin-top: 1.5rem; padding-top: 2rem; border-top: 1px solid color-mix(in oklch, var(--text) 10%, transparent); }

  @media (max-width: 768px) {
    .admin-form { padding: 2rem 1.5rem; border-radius: 24px; }
    .form-grid, .category-section { grid-template-columns: 1fr; }
    .btn-modern { width: 100%; }
  }
</style>